{
    "PostgresSettings": {
      "ConnectionString": "Host=localhost;Port=5432;Database=chat;Username=admin;Password=admin",
      "Schema": "chat"
    },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/logs/log-.txt",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter,Serilog.Formatting.Compact",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ]
  },

  "JwtSettings": {
    "Issuer": "Note",
    "Audience": "Note",
    "Authority": "Note",
    "JwtKey": "KNGjkrngkjreg0sdfddyjfyjugyijuthdgxrftygukyhjnbcfxvdfbgnh1234tb",
    "Lifetime": 15,
    "RefreshTokenValidityInDays": 7
  },
  "AllowedHosts": "*"
}